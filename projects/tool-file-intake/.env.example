# Slack — Socket Mode (pas de signing secret, pas d'URL webhook à exposer)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token : api.slack.com → ton app → Basic Information → App-Level Tokens
# → Generate Token → scope "connections:write"
SLACK_APP_TOKEN=xapp-...

# Stockage
STORAGE_BASE=/storage/Documents

# Base de données
DB_PATH=/data/intake-db/intake.db

# Agent IA (webhook appelé après chaque stockage)
AGENT_WEBHOOK_URL=

# Limites
MAX_FILE_SIZE_MB=50
